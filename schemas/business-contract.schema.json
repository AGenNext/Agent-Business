{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BusinessContract",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "tenant", "parties", "obligations", "responsibilities", "status"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "tenant": { "type": "string", "minLength": 1 },
    "parties": { "type": "array", "minItems": 2, "items": { "type": "string" } },
    "obligations": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "responsibilities": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "status": {
      "enum": ["draft", "active", "suspended", "terminated", "expired"]
    }
  }
}
